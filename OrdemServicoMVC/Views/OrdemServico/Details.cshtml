@model OrdemServicoMVC.Models.OrdemServico
@{
    ViewData["Title"] = "Detalhes da Ordem";
}

<div class="container-fluid px-3 px-md-5 py-4 fadeIn">
    <div class="order-detail-stack">
        <article class="order-detail-card" data-brutal-reveal>
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                <div>
                    <p class="text-uppercase text-muted fw-semibold mb-1" style="letter-spacing:.2em;">Ordem #@Model.Id</p>
                    <h2 class="mb-0">@Model.Titulo</h2>
                    <small class="text-muted">Aberta por @Model.UsuarioCriador?.NomeLoja em @Model.DataCriacao.ToString("dd/MM/yyyy 'às' HH:mm")</small>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="order-mobile-chip @(
                        Model.Prioridade == OrdemServicoMVC.Models.PrioridadeEnum.Alta ? "chip-prioridade-alta" :
                        Model.Prioridade == OrdemServicoMVC.Models.PrioridadeEnum.Media ? "chip-prioridade-media" :
                        "chip-prioridade-baixa")">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Prioridade @Model.Prioridade
                    </span>
                    <span class="order-mobile-chip @(
                        Model.Status == OrdemServicoMVC.Models.StatusEnum.Aberta ? "chip-status-open" :
                        Model.Status == OrdemServicoMVC.Models.StatusEnum.EmAndamento ? "chip-status-progress" :
                        "chip-status-done")">
                        <i class="bi bi-flag me-1"></i>@Model.Status.ToString().Replace("EmAndamento", "Em andamento")
                    </span>
                </div>
            </div>

            <div class="order-detail-meta mb-3">
                <span><i class="bi bi-building me-2"></i>@Model.Setor.ToString().Replace("FrenteDeCaixa", "Frente de Caixa")</span>
                <span><i class="bi bi-person-gear me-2"></i>@(Model.TecnicoResponsavel?.NomeLoja ?? "Sem técnico")</span>
                @if (Model.DataConclusao.HasValue)
                {
                    <span><i class="bi bi-check-circle me-2"></i>Concluída em @Model.DataConclusao.Value.ToString("dd/MM/yyyy HH:mm")</span>
                }
            </div>

            <div class="order-detail-actions">
                @if (User.IsInRole("Admin") || Model.UsuarioCriadorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100 w-md-auto">
                        <i class="bi bi-pencil me-2"></i>Editar Ordem
                    </a>
                }
                <a asp-controller="Mensagem" asp-action="Chat" asp-route-id="@Model.Id" class="btn btn-primary w-100 w-md-auto">
                    <i class="bi bi-chat-dots me-2"></i>Abrir Conversa
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 w-md-auto">
                    <i class="bi bi-arrow-left me-2"></i>Voltar
                </a>
            </div>
        </article>

        <article class="order-detail-card" data-brutal-reveal>
            <h5 class="order-form-section__title mb-2"><i class="bi bi-file-text me-2"></i>Descrição completa</h5>
            <p class="order-mobile-description mb-0" style="white-space:pre-wrap;">@Model.Descricao</p>
        </article>

        @if (!string.IsNullOrEmpty(Model.Observacoes))
        {
            <article class="order-detail-card" data-brutal-reveal>
                <h5 class="order-form-section__title mb-2"><i class="bi bi-chat-left-text me-2"></i>Observações</h5>
                <p class="order-mobile-description mb-0" style="white-space:pre-wrap;">@Model.Observacoes</p>
            </article>
        }

        @if (Model.Anexos != null && Model.Anexos.Any())
        {
            <article class="order-detail-card" data-brutal-reveal>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="order-form-section__title mb-0"><i class="bi bi-paperclip me-2"></i>Anexos (@Model.Anexos.Count())</h5>
                    <small class="text-muted">Clique para abrir em nova aba</small>
                </div>
                <div class="row g-3">
                    @foreach (var anexo in Model.Anexos)
                    {
                        <div class="col-6 col-md-3">
                            <div class="modern-attachment-card h-100">
                                <a href="@Url.Action("Download", "Anexo", new { id = anexo.Id })" target="_blank" class="d-block">
                                    <img src="@Url.Action("Download", "Anexo", new { id = anexo.Id })"
                                         alt="@anexo.NomeArquivo"
                                         class="modern-attachment-img" />
                                </a>
                                <div class="modern-attachment-body">
                                    <small class="text-muted d-block text-truncate">@anexo.NomeArquivo</small>
                                    <small class="text-muted">@(Math.Round(anexo.TamanhoBytes / 1024m, 1)) KB</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </article>
        }

        <article class="order-detail-card" data-brutal-reveal>
            <h5 class="order-form-section__title mb-3"><i class="bi bi-info-circle me-2"></i>Resumo</h5>
            <div class="order-detail-meta">
                <span><strong>ID:</strong> #@Model.Id</span>
                <span><strong>Técnico:</strong> @(Model.TecnicoResponsavel?.NomeLoja ?? "Não atribuído")</span>
                <span><strong>Status:</strong> @Model.Status.ToString().Replace("EmAndamento", "Em andamento")</span>
                <span><strong>Prioridade:</strong> @Model.Prioridade</span>
            </div>
        </article>
    </div>
</div>