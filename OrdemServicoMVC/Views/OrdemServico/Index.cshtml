<script>
    // Função para carregar indicadores de performance (apenas para administradores)
    function carregarIndicadoresPerformance() {
        // Verifica se o usuário é administrador e se o dashboard existe
        const dashboardContainer = document.getElementById('dashboard-container');
        if (!dashboardContainer) {
            return; // Não é administrador, não carrega indicadores
        }

        // Faz requisição para obter estatísticas
        fetch('/OrdemServico/GetEstatisticas')
            .then(response => {
                if (!response.ok) {
                    throw new Error('Erro ao carregar estatísticas');
                }
                return response.json();
            })
            .then(data => {
                // Atualiza o total de ordens abertas
                document.getElementById('total-ordens-abertas').textContent = data.totalOrdensAbertas || 0;
                
                // Atualiza ordens concluídas
                document.getElementById('ordens-concluidas').textContent = data.ordensConcluidas || 0;
                
                // Atualiza contadores por status
                let statusAberta = 0;
                let statusEmAndamento = 0;
                
                if (data.ordensPorStatus) {
                    data.ordensPorStatus.forEach(item => {
                        if (item.status === 'Aberta') {
                            statusAberta = item.quantidade;
                        } else if (item.status === 'EmAndamento') {
                            statusEmAndamento = item.quantidade;
                        }
                    });
                }
                
                document.getElementById('status-aberta').textContent = statusAberta;
                document.getElementById('status-em-andamento').textContent = statusEmAndamento;
                
                // Atualiza contador de prioridade alta
                let prioridadeAlta = 0;
                
                if (data.ordensPorPrioridade) {
                    data.ordensPorPrioridade.forEach(item => {
                        if (item.prioridade === 'Alta') {
                            prioridadeAlta = item.quantidade;
                        }
                    });
                }
                
                document.getElementById('prioridade-alta').textContent = prioridadeAlta;
                
                // Timestamp da última atualização removido
                
                console.log('Indicadores de performance atualizados com sucesso');
            })
            .catch(error => {
                console.error('Erro ao carregar indicadores de performance:', error);
                
                // Em caso de erro, exibe valores padrão
                const elementos = [
                    'total-ordens-abertas', 'ordens-concluidas', 'status-aberta', 
                    'status-em-andamento', 'prioridade-alta'
                ];
                
                elementos.forEach(id => {
                    const elemento = document.getElementById(id);
                    if (elemento) {
                        elemento.textContent = 'Erro';
                    }
                });
                
                // Timestamp da última atualização removido
            });
    }

    // Função para configurar o toggle do dashboard
    function configurarToggleDashboard() {
        const toggleButton = document.getElementById('dashboardMetricsToggle');
        const metrics = document.getElementById('dashboardMetrics');
        if (!toggleButton || !metrics) {
            return;
        }

        toggleButton.addEventListener('click', () => {
            const isExpanded = metrics.classList.toggle('is-expanded');
            toggleButton.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');

            const label = toggleButton.querySelector('.toggle-text');
            if (label) {
                label.textContent = isExpanded ? 'Ocultar indicadores' : 'Ver indicadores';
            }

            const icon = toggleButton.querySelector('.toggle-icon');
            if (icon) {
                icon.classList.toggle('is-rotated', isExpanded);
            }
        });
    }

    // Função para configurar SignalR para notificações de ordens usando conexão global
    function configureOrderSignalR() {
        console.log('Configurando SignalR para notificações de ordens...'); // Debug: configuração
        
        // Verifica se a conexão global existe
        if (typeof globalConnection !== 'undefined' && globalConnection) {
            console.log('Usando conexão SignalR global para notificações de ordens'); // Debug: conexão global
            
            // Escuta notificações de novas ordens criadas
            globalConnection.on("NewOrderCreated", function (orderData) {
                console.log('Nova ordem criada recebida via SignalR:', orderData); // Debug: nova ordem
                // Exibe notificação toast para nova ordem
                showToast(`Nova ordem criada: ${orderData.titulo} (${orderData.prioridade})`, 'success');
                
                // Atualiza indicadores de performance em tempo real (apenas para administradores)
                if (document.getElementById('dashboard-container')) {
                    carregarIndicadoresPerformance();
                }
            });

            // Escuta atualizações de status de ordens
            globalConnection.on("OrderStatusUpdated", function (orderData) {
                console.log('Status de ordem atualizado via SignalR:', orderData); // Debug: status atualizado
                
                // Determina qual campo foi alterado para exibir mensagem apropriada
                let mensagem = `Ordem ${orderData.id} atualizada`;
                
                // Usa as informações específicas do campo alterado enviadas pelo servidor
                if (orderData.campoAlterado && orderData.valorAlterado) {
                    switch (orderData.campoAlterado) {
                        case 'status':
                            mensagem = `Ordem ${orderData.id} - status alterado para: ${orderData.valorAlterado}`;
                            break;
                        case 'prioridade':
                            mensagem = `Ordem ${orderData.id} - prioridade alterada para: ${orderData.valorAlterado}`;
                            break;
                        case 'tecnico':
                            const tecnicoNome = orderData.valorAlterado === 'Nenhum' ? 'Nenhum técnico' : orderData.valorAlterado;
                            mensagem = `Ordem ${orderData.id} - técnico alterado para: ${tecnicoNome}`;
                            break;
                        default:
                            mensagem = `Ordem ${orderData.id} atualizada`;
                    }
                } else {
                    // Fallback para compatibilidade
                    mensagem = `Ordem ${orderData.id} atualizada: ${orderData.status}`;
                }
                
                // Exibe notificação toast
                showToast(mensagem, 'info');
                
                // Atualiza a linha da tabela com os novos dados
                updateOrderRowInTable(orderData);
                
                // Atualiza indicadores de performance em tempo real (apenas para administradores)
                if (document.getElementById('dashboard-container')) {
                    carregarIndicadoresPerformance();
                }
            });
        } else {
            console.warn('Conexão SignalR global não encontrada para notificações de ordens'); // Debug: conexão não encontrada
            // Tenta novamente após um pequeno delay
            setTimeout(configureOrderSignalR, 1000);
        }
    }

    // Função movida para o listener consolidado
    

</script>

