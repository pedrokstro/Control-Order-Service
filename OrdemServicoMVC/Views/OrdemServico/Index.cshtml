<script>
    // Checklist Logic
    function toggleAllOrdens(source) {
        const checkboxes = document.querySelectorAll('.ordem-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = source.checked;
        });
        atualizarContadorChecklist();
    }

    function atualizarContadorChecklist(event) {
        if (event) event.stopPropagation();
        
        const selectedCount = document.querySelectorAll('.ordem-checkbox:checked').length;
        const btn = document.getElementById('btnGerarChecklist');
        const badge = document.getElementById('badgeChecklistCount');
        
        if (btn && badge) {
            badge.textContent = selectedCount;
            if (selectedCount > 0) {
                btn.removeAttribute('disabled');
                badge.style.display = 'inline-block';
            } else {
                btn.setAttribute('disabled', 'disabled');
                badge.style.display = 'none';
            }
        }
        
        // Update "Select All" checkbox state
        const allCheckboxes = document.querySelectorAll('.ordem-checkbox');
        const checkAll = document.getElementById('checkAllOrdens');
        if (checkAll && allCheckboxes.length > 0) {
            checkAll.checked = selectedCount === allCheckboxes.length;
            checkAll.indeterminate = selectedCount > 0 && selectedCount < allCheckboxes.length;
        }
    }

    function gerarChecklist() {
        const selectedIds = Array.from(document.querySelectorAll('.ordem-checkbox:checked')).map(cb => parseInt(cb.value));
        
        if (selectedIds.length === 0) {
            alert('Selecione pelo menos uma ordem para gerar o checklist.');
            return;
        }

        const btn = document.getElementById('btnGerarChecklist');
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Gerando...';
        btn.disabled = true;

        fetch('/Relatorio/GerarChecklist', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify(selectedIds)
        })
        .then(response => {
            if (!response.ok) throw new Error('Erro na geração do arquivo');
            return response.blob();
        })
        .then(blob => {
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = `Checklist_Execucao_${new Date().toISOString().slice(0,10)}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            
            // Show success toast
            // Reset button state
            btn.innerHTML = originalText;
            btn.disabled = false;
        })
        .catch(error => {
            console.error('Erro:', error);
            alert('Ocorreu um erro ao gerar o checklist. Tente novamente.');
            btn.innerHTML = originalText;
            btn.disabled = false;
        });
    }
</script>