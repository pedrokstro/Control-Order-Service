@model ErrorViewModel
@{
    ViewData["Title"] = "Erro - Sistema de Ordem de Serviço";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Erro no Sistema</h1>
                </div>
                <div class="card-body">
                    <h4 class="text-danger mb-3">Ocorreu um erro ao processar sua solicitação.</h4>
                    
                    <div class="alert alert-info">
                        <p class="mb-0">
                            <strong>O que aconteceu?</strong> O sistema encontrou um problema inesperado.
                            Nossa equipe foi notificada automaticamente sobre este erro.
                        </p>
                    </div>

                    <!-- Informações básicas do erro -->
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <strong>Data/Hora:</strong> @Model.ErrorTime.ToString("dd/MM/yyyy HH:mm:ss")
                        </div>
                        @if (Model.StatusCode > 0)
                        {
                            <div class="col-md-6">
                                <strong>Código do Erro:</strong> @Model.StatusCode
                            </div>
                        }
                    </div>

                    @if (Model.ShowRequestId)
                    {
                        <div class="mt-3">
                            <strong>ID de Rastreamento:</strong> 
                            <code class="bg-light p-1 rounded">@Model.RequestId</code>
                            <small class="text-muted d-block mt-1">
                                Use este código ao entrar em contato com o suporte técnico.
                            </small>
                        </div>
                    }

                    <!-- Informações detalhadas para desenvolvimento -->
                    @if (Model.ShowDetails)
                    {
                        <div class="mt-4">
                            <div class="alert alert-warning">
                                <h5><i class="fas fa-tools"></i> Informações de Desenvolvimento</h5>
                                
                                @if (!string.IsNullOrEmpty(Model.RequestPath))
                                {
                                    <p><strong>Caminho da Requisição:</strong> <code>@Model.RequestPath</code></p>
                                }
                                
                                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                                {
                                    <p><strong>Mensagem do Erro:</strong></p>
                                    <pre class="bg-light p-2 rounded">@Model.ErrorMessage</pre>
                                }
                                
                                <hr>
                                <small class="text-muted">
                                    <strong>Atenção:</strong> O ambiente de desenvolvimento não deve ser habilitado 
                                    para aplicações em produção, pois pode expor informações sensíveis.
                                </small>
                            </div>
                        </div>
                    }

                    <!-- Ações sugeridas -->
                    <div class="mt-4">
                        <h5>O que você pode fazer:</h5>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-arrow-left text-primary"></i> <a href="javascript:history.back()" class="text-decoration-none">Voltar à página anterior</a></li>
                            <li><i class="fas fa-home text-success"></i> <a href="@Url.Action("Login", "Account")" class="text-decoration-none">Ir para a página inicial</a></li>
                            <li><i class="fas fa-envelope text-info"></i> <a href="mailto:suporte@quartettocontrolservice.com" class="text-decoration-none">Entrar em contato com o suporte</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
