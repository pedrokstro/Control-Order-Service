    <!-- Global Loading Script -->
    <script>
        function showLoading(title = 'Processando...', message = 'Enviando anexos e salvando dados') {
            const overlay = document.getElementById('globalAppLoader');
            const titleEl = document.getElementById('loaderTitle');
            const messageEl = document.getElementById('loaderMessage');
            const progressBar = document.getElementById('loaderProgressBar');
            const percentEl = document.getElementById('loaderPercent');
            
            if (overlay) {
                if (titleEl) titleEl.innerText = title;
                if (messageEl) messageEl.innerText = message;
                if (progressBar) progressBar.style.width = '0%';
                if (percentEl) percentEl.innerText = '0%';
                
                overlay.classList.remove('d-none');
                overlay.style.opacity = '1';
            }
        }

        function updateLoadingProgress(percent) {
            const progressBar = document.getElementById('loaderProgressBar');
            const percentEl = document.getElementById('loaderPercent');
            if (progressBar) progressBar.style.width = percent + '%';
            if (percentEl) percentEl.innerText = Math.round(percent) + '%';
        }
        
        function hideLoading() {
            const overlay = document.getElementById('globalAppLoader');
            if (overlay) {
                overlay.style.opacity = '0';
                setTimeout(() => {
                    overlay.classList.add('d-none');
                }, 300);
            }
        }

        // Auto-show loading on form submissions with attachments
        document.addEventListener('submit', function(e) {
            const form = e.target;
            
            // Ignora formulários que já estão sendo tratados por AJAX/Fetch customizado
            if (e.defaultPrevented) return;

            const fileInputs = form.querySelectorAll('input[type="file"]');
            let hasFiles = false;
            fileInputs.forEach(input => {
                if (input.files && input.files.length > 0) hasFiles = true;
            });
            
            if (form.getAttribute('enctype') === 'multipart/form-data' || hasFiles) {
                showLoading('Enviando...', 'Por favor, aguarde enquanto processamos seus arquivos.');
                
                // Simulação de progresso para posts normais de formulário
                // (Já que o navegador não expõe o progresso do POST síncrono facilmente)
                let simulatedPercent = 0;
                const interval = setInterval(() => {
                    if (simulatedPercent < 90) {
                        simulatedPercent += Math.random() * 5;
                        if (simulatedPercent > 90) simulatedPercent = 90;
                        updateLoadingProgress(simulatedPercent);
                    } else {
                        clearInterval(interval);
                    }
                }, 500);

                // Garante que o intervalo pare se a página descarregar (redirecionamento)
                window.addEventListener('unload', () => clearInterval(interval));
            }
        });
    </script>
    
