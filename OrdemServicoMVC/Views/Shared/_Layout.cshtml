    <!-- Favicon - ReferÃªncia explÃ­cita para garantir atualizaÃ§Ã£o -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    
    <!-- Estilos para o toggle do filtro -->
    <style>
        /* BotÃ£o toggle do filtro - Cor sÃ³lida igual ao botÃ£o de configuraÃ§Ãµes */
        .filter-toggle-btn {
            background: var(--primary-color);
            border: 1px solid var(--primary-color);
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .filter-toggle-btn:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
            color: white;
        }
        
        .filter-toggle-btn:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.3);
        }
        
        /* Ãcone do toggle com animaÃ§Ã£o */
        .filter-toggle-icon {
            transition: transform 0.3s ease;
        }
        
        .filter-toggle-btn[aria-expanded="true"] .filter-toggle-icon {
            transform: rotate(180deg);
        }
        
        /* Container do filtro com animaÃ§Ã£o */
        .filter-container {
            overflow: hidden;
            transition: all 0.4s ease;
        }
        
        .filter-container.collapsed {
            max-height: 0;
            opacity: 0;
            margin-bottom: 0 !important;
        }
        
        .filter-container:not(.collapsed) {
            max-height: 1000px;
            opacity: 1;
        }
        
        /* Header do filtro com toggle */
        .filter-header-with-toggle {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        
        .filter-title {
            margin: 0;
            color: #333;
            font-weight: 600;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
        }
        
        /* Responsividade para filtros */
        @@media (max-width: 768px) {
            .filter-header-with-toggle {
                flex-direction: column;
                gap: 12px;
                align-items: stretch;
            }
            
            .filter-title {
                font-size: 16px;
                justify-content: center;
            }
            
            .filter-subtitle {
                display: none;
            }
            
            .filter-toggle-btn {
                width: 100%;
                justify-content: center;
                padding: 10px 16px;
            }
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999999;
            transition: opacity 0.3s ease;
        }
        
        .loading-content {
            text-align: center;
            padding: 3rem;
            border-radius: 28px;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            max-width: 450px;
            width: 92%;
            box-shadow: 0 25px 70px -12px rgba(0, 0, 0, 0.7);
        }

        .loader-progress-container {
            width: 100%;
            height: 12px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            margin: 2rem 0 1rem;
            overflow: hidden;
            position: relative;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
        }

        .loader-progress-bar {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #3b82f6, #60a5fa, #3b82f6);
            background-size: 200% 100%;
            border-radius: 20px;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            animation: shimmer 2s linear infinite;
        }

        @@keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        .loader-percentage {
            color: #3b82f6;
            font-weight: 800;
            font-size: 2.5rem;
            letter-spacing: -1px;
            margin-bottom: 0.5rem;
            display: block;
            text-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
        }

        .loader-text h5 {
            font-weight: 600;
            font-size: 1.25rem;
            letter-spacing: 0.5px;
        }
        
        @@media (max-width: 576px) {
            .filter-title {
                font-size: 14px;
            }
        }
    
            .filter-title-text {
                font-size: 14px;
            }
            
            .filter-toggle-btn {
                padding: 8px 12px;
                font-size: 13px;
            }
            
            .toggle-text {
                font-size: 13px;
            }
        }

        /* Header oculto em mobile: remove padding-top desnecessário do conteúdo */
        @@media (max-width: 991.98px) {
            .container-fluid.py-4 {
                padding-top: 0.75rem !important;
            }
        }
    </style>
</head>
