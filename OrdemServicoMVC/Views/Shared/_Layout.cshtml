    <!-- Scripts essenciais carregados imediatamente -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
    <!-- Sistema de Lazy Loading -->
    <script src="~/js/lazy-loader.js" asp-append-version="true"></script>
    
    <!-- Carregadores de componentes específicos -->
     <script src="~/js/components/validation-loader.js" asp-append-version="true"></script>
     <script src="~/js/components/bootstrap-loader.js" asp-append-version="true"></script>
     <script src="~/js/components/reports-loader.js" asp-append-version="true"></script>
     <script src="~/js/components/image-lazy-loader.js" asp-append-version="true"></script>
    
    <!-- Bootstrap carregado sob demanda -->
     <script>
         // Aguarda o DOM estar pronto e os carregadores estarem disponíveis
         document.addEventListener('DOMContentLoaded', function() {
             // Pequeno delay para garantir que todos os scripts foram carregados
             setTimeout(() => {
                 // Verifica se o lazyLoader está disponível
                 if (typeof lazyLoader !== 'undefined') {
                     // Carrega Bootstrap de forma assíncrona
                     lazyLoader.loadScript('/lib/bootstrap/dist/js/bootstrap.bundle.min.js', 'bootstrap-bundle')
                         .then(() => {
                             console.log('✅ Bootstrap carregado via lazy loading');
                             
                             // Aguarda um pouco mais para garantir que o bootstrapLoader foi inicializado
                             setTimeout(() => {
                                 // Inicializa componentes Bootstrap automaticamente
                                 if (typeof bootstrapLoader !== 'undefined' && bootstrapLoader.autoLoadComponents) {
                                     bootstrapLoader.autoLoadComponents();
                                 } else {
                                     console.warn('⚠️ BootstrapLoader não está disponível ainda');
                                 }
                             }, 100);
                         }).catch(error => {
                             console.error('❌ Erro ao carregar Bootstrap:', error);
                         });
                 } else {
                     console.error('❌ LazyLoader não está disponível');
                 }
             }, 100);
         });
     </script>
    
    <!-- Scripts principais -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/pwa.js" asp-append-version="true"></script>
    
    <!-- BRUTALIST ANIMATIONS SYSTEM -->
    <script src="~/js/brutalist-animations.js" asp-append-version="true"></script>
    
    <!-- Tratamento global de erros para suprimir erros de extensÃµes do Chrome -->
    <script>
        // Suprime erros específicos de extensões do Chrome que não afetam a funcionalidade
        window.addEventListener('error', function(event) {
            // Verifica se é o erro específico das extensões do Chrome
            if (event.message && event.message.includes('A listener indicated an asynchronous response by returning true')) {
                // Suprime este erro especÃ­fico pois Ã© causado por extensÃµes do navegador
                event.preventDefault();
                return true;
            }
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const scrollBtn = document.getElementById('scrollToTopButton');
            if (!scrollBtn) {
                return;
            }

            const toggleScrollTopVisibility = () => {
                if (window.scrollY > 400) {
                    scrollBtn.classList.add('visible');
                } else {
                    scrollBtn.classList.remove('visible');
                }
            };

            scrollBtn.addEventListener('click', function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            window.addEventListener('scroll', toggleScrollTopVisibility);
            toggleScrollTopVisibility();
        });
    </script>

    @if (User.Identity.IsAuthenticated)
    {
        <!-- SignalR carregado sob demanda via LazyLoader -->
        <script>
            // Variável global para conexão SignalR (compatibilidade)
            let globalConnection = null;
            
            // Função para inicializar SignalR sob demanda
            async function initializeSignalR() {
                try {
                    console.log('🚀 Inicializando SignalR sob demanda...');
                    
                    // Carrega o gerenciador SignalR
                    await window.lazyLoader.loadScript('/js/components/signalr-manager.js', 'signalr-manager');
                    
                    // Obtém a conexão global
                    globalConnection = await window.signalRManager.getGlobalConnection();
                    
                    // Configura listeners para notificações globais
                    setupGlobalSignalRListeners();
                    
                    // Carrega contador inicial de mensagens não lidas
                    loadUnreadMessagesCount();
                    
                    console.log('✅ SignalR inicializado com sucesso!');
                    
                } catch (error) {
                    console.error('❌ Erro ao inicializar SignalR:', error);
                    // Retry após 5 segundos
                    setTimeout(initializeSignalR, 5000);
                }
            }

            // ---------- FAB CHAT PANEL ----------
            let fabPanelLoaded = false;
            let fabPanelLoading = false;

            document.addEventListener('DOMContentLoaded', function () {
                const fabButton = document.querySelector('.fab-chat');
                const fabPanel = document.getElementById('fabChatPanel');
                const fabClose = document.getElementById('fabClosePanel');

                if (!fabButton || !fabPanel) return;

                fabButton.addEventListener('click', function (e) {
                    e.preventDefault();
                    toggleFabPanel();
                });

                if (fabClose) {
                    fabClose.addEventListener('click', function () {
                        hideFabPanel();
                    });
                }

                document.addEventListener('click', function (event) {
                    if (!fabPanel.classList.contains('visible')) return;
                    if (event.target.closest('.fab-panel') || event.target.closest('.fab-chat')) return;
                    hideFabPanel();
                });
            });

            function toggleFabPanel() {
                const panel = document.getElementById('fabChatPanel');
                if (!panel) return;

            	if (panel.classList.contains('visible')) {
                    hideFabPanel();
                } else {
                    panel.classList.add('visible');
                    if (!fabPanelLoaded) {
                        loadFabChatPanel();
                    }
                }
            }

            function hideFabPanel() {
                const panel = document.getElementById('fabChatPanel');
                if (panel) {
                    panel.classList.remove('visible');
                }
            }

            async function loadFabChatPanel() {
                if (fabPanelLoading) return;
                fabPanelLoading = true;

                const listContainer = document.getElementById('fabChatList');
                const emptyState = document.getElementById('fabEmptyState');
                const subtitle = document.getElementById('fabPanelSubtitle');

                if (subtitle) subtitle.textContent = 'Carregando ordens...';
                if (listContainer) listContainer.innerHTML = '';
                if (emptyState) emptyState.style.display = 'none';

                try {
                    const response = await fetch('/Mensagem/OrdensNaoLidas');
                    if (!response.ok) throw new Error('Erro ao buscar ordens');

                    const data = await response.json();
                    const ordens = data?.ordens || [];

                    if (ordens.length === 0) {
                        if (emptyState) emptyState.style.display = 'block';
                        if (subtitle) subtitle.textContent = 'Sem novas mensagens';
                    } else {
                        renderFabChatList(ordens);
                        if (subtitle) subtitle.textContent = `${ordens.length} ordem(ns) com novidades`;
                    }

                    fabPanelLoaded = true;
                } catch (error) {
                    console.error('Erro ao carregar ordens não lidas:', error);
                    if (subtitle) subtitle.textContent = 'Não foi possível carregar';
                } finally {
                    fabPanelLoading = false;
                }
            }

            function renderFabChatList(ordens) {
                const listContainer = document.getElementById('fabChatList');
                const emptyState = document.getElementById('fabEmptyState');

                if (!listContainer) return;
                listContainer.innerHTML = '';

                ordens.forEach(ordem => {
                    const link = document.createElement('a');
                    link.href = `/Mensagem/Chat/${ordem.id}`;
                    link.className = 'fab-chat-item';
                    link.innerHTML = `
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <h6>${ordem.titulo || 'Sem título'}</h6>
                            <span class="fab-chat-unread">${ordem.unread}</span>
                        </div>
                        <div class="fab-chat-meta">
                            <span><i class="bi bi-shop me-1"></i>${ordem.loja || 'Loja não informada'}</span>
                            <span><i class="bi bi-person-gear me-1"></i>${ordem.tecnico || 'Não atribuído'}</span>
                        </div>
                    `;
                    listContainer.appendChild(link);
                });

                if (emptyState) emptyState.style.display = ordens.length === 0 ? 'block' : 'none';
            }
            
            // Configura listeners globais do SignalR
            function setupGlobalSignalRListeners() {
                if (!globalConnection) return;
                
                // Escuta atualizações do contador de mensagens não lidas
                globalConnection.on("UnreadMessagesCount", function (data) {
                    updateUnreadBadge(data.count);
                });
                
                // Escuta atualizações do contador global de mensagens não lidas
                globalConnection.on("GlobalUnreadMessagesCount", function (data) {
                    updateUnreadBadge(data.count);
                });
                
                // Listener para notificações de sistema
                globalConnection.on('NotificacaoSistema', function(notification) {
                    console.log('🔔 Notificação do sistema:', notification);
                    
                    // Exibe notificação (pode ser implementado com toast)
                    if (notification.message) {
                        // Implementar sistema de toast aqui
                        console.log('Notificação:', notification.message);
                    }
                });
                
                console.log('👂 Listeners globais do SignalR configurados');
            }
            
            // FunÃ§Ã£o para carregar o contador inicial de mensagens nÃ£o lidas
            async function loadUnreadMessagesCount() {
                try {
                    const response = await fetch('/Mensagem/ContarNaoLidas');
                    if (response.ok) {
                        const data = await response.json();
                        updateUnreadBadge(data.count || 0);
                    }
                } catch (error) {
                    console.error('Erro ao carregar contador de mensagens:', error);
                }
            }
            
            // FunÃ§Ã£o para atualizar o badge de mensagens nÃ£o lidas
            function updateUnreadBadge(count) {
                const badge = document.getElementById('unread-badge');
                const fabBadge = document.getElementById('fabUnreadBadge');
                
                if (badge) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.display = 'inline';
                    } else {
                        badge.style.display = 'none';
                    }
                }
                
                // Atualiza também o badge do FAB
                if (fabBadge) {
                    if (count > 0) {
                        fabBadge.textContent = count > 99 ? '99+' : count;
                        fabBadge.style.display = 'flex';
                    } else {
                        fabBadge.style.display = 'none';
                    }
                }
            }
            
            // FunÃ§Ã£o para abrir o modal de confirmaÃ§Ã£o de limpeza completa
            function confirmarLimpezaCompleta() {
                // Reseta o checkbox, campo de senha e desabilita o botÃ£o
                document.getElementById('confirmarLimpeza').checked = false;
                if (document.getElementById('senhaLimpeza')) {
                    document.getElementById('senhaLimpeza').value = '';
                }
                document.getElementById('btnConfirmarLimpeza').disabled = true;
                
                // Exibe o modal
                new bootstrap.Modal(document.getElementById('modalLimpezaCompleta')).show();
            }
            
            // FunÃ§Ã£o para executar a limpeza completa
            function executarLimpezaCompleta() {
                // Valida a senha
                const senha = document.getElementById('senhaLimpeza').value;
                if (!senha) {
                    alert('Por favor, digite a senha de administrador para confirmar.');
                    return;
                }

                // Desabilita o botÃ£o para evitar cliques mÃºltiplos
                const btnConfirmar = document.getElementById('btnConfirmarLimpeza');
                btnConfirmar.disabled = true;
                btnConfirmar.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Executando...';
                
                // Faz a requisiÃ§Ã£o AJAX para o endpoint de limpeza
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const bodyParams = new URLSearchParams();
                if (token) bodyParams.append('__RequestVerificationToken', token);
                bodyParams.append('senha', senha);

                fetch('/OrdemServico/LimparTodasOrdens', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: bodyParams.toString()
                })
                .then(response => response.json())
                .then(data => {
                    // Fecha o modal
                    bootstrap.Modal.getInstance(document.getElementById('modalLimpezaCompleta')).hide();
                    
                    if (data.success) {
                         // Exibe mensagem de sucesso
                         alert(data.message);
                         
                         // Recarrega a pÃ¡gina apÃ³s 2 segundos para mostrar o resultado
                         setTimeout(() => {
                             window.location.reload();
                         }, 2000);
                     } else {
                         // Exibe mensagem de erro
                         alert(data.message);
                        
                        // Reabilita o botÃ£o
                        btnConfirmar.disabled = false;
                        btnConfirmar.innerHTML = '<i class="bi bi-trash3 me-2"></i>Confirmar Limpeza';
                    }
                })
                .catch(error => {
                    console.error('Erro:', error);
                    
                    // Fecha o modal
                    bootstrap.Modal.getInstance(document.getElementById('modalLimpezaCompleta')).hide();
                    
                    // Exibe mensagem de erro
                     alert('Ocorreu um erro inesperado durante a limpeza.');
                    
                    // Reabilita o botÃ£o
                    btnConfirmar.disabled = false;
                    btnConfirmar.innerHTML = '<i class="bi bi-trash3 me-2"></i>Confirmar Limpeza';
                });
            }
            
            // Função para obter conexão SignalR (compatibilidade com código existente)
            window.getGlobalSignalRConnection = function() {
                return globalConnection;
            };
            
            // Event listener para habilitar/desabilitar o botÃ£o de confirmaÃ§Ã£o
            document.addEventListener('DOMContentLoaded', function() {
                const checkbox = document.getElementById('confirmarLimpeza');
                const btnConfirmar = document.getElementById('btnConfirmarLimpeza');
                
                if (checkbox && btnConfirmar) {
                    checkbox.addEventListener('change', function() {
                        btnConfirmar.disabled = !this.checked;
                    });
                }
                
                // Funcionalidade do toggle do filtro
                initializeFilterToggle();
                
                // Inicializa SignalR quando a página carrega (com delay para não bloquear)
                // Delay de 1 segundo para não impactar o carregamento inicial
                setTimeout(initializeSignalR, 1000);
                
                // Configura monitoramento de sessão
                setupSessionMonitoring();
            });
            
            // FunÃ§Ã£o para inicializar o toggle do filtro
            function initializeFilterToggle() {
                const toggleBtn = document.querySelector('.filter-toggle-btn');
                const filterContainer = document.getElementById('filterContainer');
                const toggleText = document.querySelector('.toggle-text');
                
                if (toggleBtn && filterContainer) {
                    // Configura o filtro para iniciar sempre fechado
                    filterContainer.classList.add('collapsed');
                    toggleBtn.setAttribute('aria-expanded', 'false');
                    
                    // Event listener para o botÃ£o toggle
                    toggleBtn.addEventListener('click', function() {
                        const isExpanded = this.getAttribute('aria-expanded') === 'true';
                        
                        // Atualiza o estado do botÃ£o
                        this.setAttribute('aria-expanded', !isExpanded);
                        
                        // Atualiza o texto do botÃ£o
                        if (toggleText) {
                            toggleText.textContent = isExpanded ? 'Mostrar Filtros' : 'Ocultar Filtros';
                        }
                        
                        // Controla a visibilidade do filtro
                        if (isExpanded) {
                            // Fechando o filtro
                            filterContainer.classList.add('collapsed');
                        } else {
                            // Abrindo o filtro
                            filterContainer.classList.remove('collapsed');
                        }
                    });
                    
                    // Event listener para quando o collapse do Bootstrap termina
                    filterContainer.addEventListener('shown.bs.collapse', function() {
                        filterContainer.classList.remove('collapsed');
                    });
                    
                    filterContainer.addEventListener('hidden.bs.collapse', function() {
                        filterContainer.classList.add('collapsed');
                    });
                }
            }

        </script>
    }
    
