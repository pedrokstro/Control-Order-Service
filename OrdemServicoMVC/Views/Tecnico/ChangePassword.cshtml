@model OrdemServicoMVC.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Alterar Senha do Técnico";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-key"></i> @ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i>
                        Alterando senha para o técnico: <strong>@Model.UserName</strong>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        <input asp-for="UserId" type="hidden" />
                        <input asp-for="UserName" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="NovaSenha" class="form-label">Nova Senha</label>
                            <input asp-for="NovaSenha" class="form-control" type="password" placeholder="Digite a nova senha" />
                            <span asp-validation-for="NovaSenha" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmarNovaSenha" class="form-label">Confirmar Nova Senha</label>
                            <input asp-for="ConfirmarNovaSenha" class="form-control" type="password" placeholder="Confirme a nova senha" />
                            <span asp-validation-for="ConfirmarNovaSenha" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Voltar
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-key"></i> Alterar Senha
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}