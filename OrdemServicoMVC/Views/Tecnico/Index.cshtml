@model IEnumerable<OrdemServicoMVC.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Gerenciar Técnicos";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="management-header">
                        <div class="management-header__titles">
                            <a asp-controller="OrdemServico" asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center">
                                <i class="bi bi-arrow-left me-2"></i>
                                Voltar
                            </a>
                            <div>
                                <h3 class="mb-0">@ViewData["Title"]</h3>
                                <small class="text-muted">Cadastre e mantenha sua equipe técnica</small>
                            </div>
                        </div>
                        <div class="management-header__actions">
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="bi bi-person-plus me-2"></i>Novo Técnico
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                        <div class="management-mobile-list">
                            @foreach (var tecnico in Model)
                            {
                                <article class="management-mobile-card">
                                    <div class="management-mobile-card__title">
                                    <div>
                                        <strong>@tecnico.NomeLoja</strong>
                                        <span class="badge bg-info ms-2">
                                            <i class="bi bi-person-badge me-1"></i>Técnico
                                        </span>
                                    </div>
                                    <small class="text-muted">@tecnico.DataCriacao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="management-mobile-card__meta">
                                        <span><i class="bi bi-envelope me-1"></i>@tecnico.Email</span>
                                        <span><i class="bi bi-phone me-1"></i>@tecnico.UserName</span>
                                        <span>
                                            @if (tecnico.EmailConfirmed)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ativo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pendente</span>
                                            }
                                        </span>
                                    </div>
                                    <div class="management-mobile-card__actions">
                                        <a asp-action="Edit" asp-route-id="@tecnico.Id" class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-pencil me-1"></i>Editar
                                        </a>
                                        <a asp-action="ChangePassword" asp-route-id="@tecnico.Id" class="btn btn-outline-info btn-sm">
                                            <i class="bi bi-key me-1"></i>Senha
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@tecnico.Id" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash me-1"></i>Excluir
                                        </a>
                                    </div>
                                </article>
                            }
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-responsive management-desktop-table">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Nome do Técnico</th>
                                        <th>Email</th>
                                        <th>Data de Criação</th>
                                        <th>Status</th>
                                        <th class="text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tecnico in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@tecnico.NomeLoja</strong>
                                                <br>
                                                <small class="text-muted">@tecnico.UserName</small>
                                            </td>
                                            <td>@tecnico.Email</td>
                                            <td>@tecnico.DataCriacao.ToString("dd/MM/yyyy 'às' HH:mm")</td>
                                            <td>
                                                @if (tecnico.EmailConfirmed)
                                                {
                                                    <span class="badge bg-success">Ativo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pendente</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Edit" asp-route-id="@tecnico.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a asp-action="ChangePassword" asp-route-id="@tecnico.Id" class="btn btn-sm btn-outline-info" title="Alterar Senha">
                                                        <i class="bi bi-key"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@tecnico.Id" class="btn btn-sm btn-outline-danger" title="Excluir">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-people display-1 text-muted mb-3"></i>
                            <h5 class="text-muted">Nenhum técnico cadastrado</h5>
                            <p class="text-muted">Clique em "Novo Técnico" para adicionar o primeiro técnico.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>