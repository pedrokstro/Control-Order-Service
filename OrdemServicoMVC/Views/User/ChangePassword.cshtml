@model OrdemServicoMVC.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Alterar Senha";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-key me-2"></i>
                    Alterar Senha
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Alterando senha para: <strong>@Model.UserName</strong> (@Model.NomeLoja)
                </div>
                
                <form asp-action="ChangePassword" method="post">
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="UserName" type="hidden" />
                    <input asp-for="NomeLoja" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="NovaSenha" class="form-label"></label>
                        <input asp-for="NovaSenha" class="form-control" type="password" />
                        <span asp-validation-for="NovaSenha" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ConfirmarNovaSenha" class="form-label"></label>
                        <input asp-for="ConfirmarNovaSenha" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmarNovaSenha" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>
                            Voltar
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-key me-2"></i>
                            Alterar Senha
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}