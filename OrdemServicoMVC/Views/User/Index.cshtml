@model IEnumerable<OrdemServicoMVC.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Gerenciar Usuários";
}

<div class="management-header">
    <div class="management-header__titles">
        <a asp-controller="OrdemServico" asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center">
            <i class="bi bi-arrow-left me-2"></i>
            Voltar
        </a>
        <div>
            <h2 class="mb-0">
                <i class="bi bi-people me-2"></i>
                Gerenciar Usuários
            </h2>
            <small class="text-muted">Controle de lojas, acessos e status</small>
        </div>
    </div>
    <div class="management-header__actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus me-2"></i>
            Novo Usuário
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive management-desktop-table">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nome da Loja</th>
                            <th>Email</th>
                            <th>Tipo</th>
                            <th>Data de Criação</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-shop me-2 text-primary"></i>
                                        <div>
                                            <strong>@user.NomeLoja</strong>
                                            <br />
                                            <small class="text-muted">
                                                @(user.IsAdmin ? "Administrador" : "Funcionário")
                                            </small>
                                        </div>
                                    </div>
                                    <small class="text-muted">@user.DataCriacao.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td>
                                    <span class="text-muted">@user.Email</span>
                                </td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-shield-fill me-1"></i>
                                            Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-person me-1"></i>
                                            Funcionário
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small>@user.DataCriacao.ToString("dd/MM/yyyy 'às' HH:mm")</small>
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>
                                            Ativo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">
                                            <i class="bi bi-clock me-1"></i>
                                            Pendente
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="ChangePassword" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info" title="Alterar Senha">
                                            <i class="bi bi-key"></i>
                                        </a>
                                        @if (user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Excluir" onclick="confirmarExclusao('@user.Id', '@user.NomeLoja')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="management-mobile-list">
                @foreach (var user in Model)
                {
                    <article class="management-mobile-card">
                        <div class="management-mobile-card__title">
                            <div>
                                <strong>@user.NomeLoja</strong>
                                @if (user.IsAdmin)
                                {
                                    <span class="badge bg-danger ms-2"><i class="bi bi-shield-lock me-1"></i>Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary ms-2"><i class="bi bi-person me-1"></i>Funcionário</span>
                                }
                            </div>
                            <small class="text-muted">@user.DataCriacao.ToString("dd/MM/yyyy")</small>
                        </div>
                        <div class="management-mobile-card__meta">
                            <span><i class="bi bi-envelope me-1"></i>@user.Email</span>
                            <span><i class="bi bi-clock me-1"></i>@user.DataCriacao.ToString("HH:mm")</span>
                            <span>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pendente</span>
                                }
                            </span>
                        </div>
                        <div class="management-mobile-card__actions">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil me-1"></i>Editar
                            </a>
                            <a asp-action="ChangePassword" asp-route-id="@user.Id" class="btn btn-outline-info btn-sm">
                                <i class="bi bi-key me-1"></i>Senha
                            </a>
                            @if (user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="confirmarExclusao('@user.Id', '@user.NomeLoja')">
                                    <i class="bi bi-trash me-1"></i>Excluir
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size: 4rem; color: #6c757d;"></i>
                <h4 class="mt-3 text-muted">Nenhum usuário encontrado</h4>
                <p class="text-muted">Clique no botão "Novo Usuário" para criar o primeiro usuário.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>
                    Criar primeiro usuário
                </a>
            </div>
        }
    </div>
</div>

<!-- Modal de confirmação de exclusão -->
<div class="modal fade" id="modalExclusao" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                    Confirmar Exclusão
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir o usuário <strong id="nomeUsuario"></strong>?</p>
                <p class="text-muted">Esta ação não pode ser desfeita e todas as ordens de serviço criadas por este usuário serão mantidas.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="formExclusao" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-2"></i>
                        Excluir
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarExclusao(id, nome) {
            document.getElementById('nomeUsuario').textContent = nome;
            document.getElementById('formExclusao').action = '@Url.Action("Delete")/' + id;
            new bootstrap.Modal(document.getElementById('modalExclusao')).show();
        }

        // Auto-hide alerts after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });
    </script>
}