{
  "ConnectionStrings": {
    // String de conexão para produção - DEVE ser configurada no servidor
    "DefaultConnection": "Data Source=ordemservico_prod.db",
    "DatabaseProvider": "SQLite",
    // Para MySQL em produção, descomente e configure:
    // "MySQLConnection": "Server=seu_servidor;Database=OrdemServicoDB_Prod;Uid=usuario_prod;Pwd=senha_segura;"
  },
  "Logging": {
    "LogLevel": {
      // Configurações de log otimizadas para produção
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error",
      "System": "Error"
    },
    // Configuração para logs em arquivo (opcional)
    "File": {
      "Path": "logs/app-{Date}.log",
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  // Configurações de segurança para produção
  "Security": {
    "RequireHttps": false,
    "UseHsts": false,
    "HstsMaxAge": 31536000
  },
  // Hosts permitidos em produção - CONFIGURE CONFORME SEU DOMÍNIO
  "AllowedHosts": "localhost;seu-dominio.com;*.seu-dominio.com;quartettocontrolservice.runasp.net",
  
  // Configurações específicas da aplicação
  "Application": {
    "Environment": "Production",
    "EnableDetailedErrors": false,
    "EnableDeveloperExceptionPage": false
  }
}